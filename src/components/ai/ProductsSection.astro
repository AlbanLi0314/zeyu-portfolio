---
import ProjectCard from './ProjectCard.astro';
import AlsoBuilt from './AlsoBuilt.astro';

import resonanceImg from '@/assets/ai/resonance.png';
import echoImg from '@/assets/ai/echo.png';
import erCompanionImg from '@/assets/ai/er-companion.png';
import erCompanionHwImg from '@/assets/ai/er-companion-hw.png';
---

<section id="products" class="mb-16 md:mb-20 scroll-mt-28 md:scroll-mt-32 pt-8 border-t border-base-300 fade-in-up">
  <h2 class="text-2xl md:text-3xl font-bold mb-10 text-primary">How I Build and Ship AI Tools</h2>

  <div class="flex flex-col gap-8">
    <!-- Featured: ER Companion -->
    <ProjectCard
      title="ER Companion (CareBridge)"
      description="155 million ED visits a year — non-English-speaking patients wait 5.4 min longer to be roomed and 15.6 min longer for disposition. We built the layer that stays: a voice pipeline in 8 languages that listens continuously, flags changes the moment they happen, and puts the patient's exact words — not an AI summary — in front of the nurse in real time. Paired with a wristband feeding fall detection and vitals into the same stream."
      imageSrc={erCompanionImg}
      images={[erCompanionImg, erCompanionHwImg]}
      tags={['React 19', 'Gemini Live API', 'WebSocket', 'Zustand', 'Firebase', 'Wearable Hardware', 'Cornell AI Health Hackathon', 'Winner']}
      tagLinks={{ 'Cornell AI Health Hackathon': 'https://hackathon.cornell.edu/health' }}
      metrics="Best Hardware Prize, Cornell AI Health Hackathon · 8 languages · Real-time nurse dashboard · WCAG AA accessible"
      href="/go?url=https://github.com/AlbanLi0314/er-companion"
      ctaText="View on GitHub"
      href2="/go?url=https://www.youtube.com/watch?v=sfNbcSTc1aE"
      ctaText2="Software Demo"
      href3="/go?url=https://www.youtube.com/watch?v=PdG9uu5Dodc"
      ctaText3="Hardware Demo"
      external={true}
      featured={true}
    />

    <!-- Featured: Resonance -->
    <ProjectCard
      title="Resonance"
      description="The perfect person to discuss that paper with is probably right on your campus — you just don't know it yet. Upload it, chat with Gemini, and we'll connect you."
      imageSrc={resonanceImg}
      tags={['RAG', 'Semantic Search', 'Multi-LLM', 'Gemini 3 Hackathon']}
      tagLinks={{ 'Gemini 3 Hackathon': 'https://gemini3.devpost.com/' }}
      metrics="78% first-match accuracy · 230 Cornell researchers indexed · Hybrid FAISS + BM25 search"
      href="/go?url=https://github.com/AlbanLi0314/resonance"
      ctaText="View on GitHub"
      href2="/go?url=https://resonance-aounkapvlodwxrz2n49wye.streamlit.app"
      ctaText2="Try it now"
      external={true}
      featured={true}
    />

    <!-- Featured: Echo -->
    <ProjectCard
      title="Echo (回响)"
      description="Reconnecting after a falling out is emotionally risky — you don't know if they're open to it, and one message can make things worse. Echo lets both people privately signal their intention first. Only when there's mutual openness does it reveal a match, so no one has to make the first move alone."
      imageSrc={echoImg}
      tags={['React 18', 'Firebase Auth', 'Gemini API', 'NVC Analysis', 'Vercel']}
      metrics="Double-blind matching · SMS verification · Gemini NVC message check · Real-time sync · EN/中文 · 988 crisis resources"
      href="/go?url=https://echo-app-ebon.vercel.app"
      ctaText="Try it now"
      external={true}
      featured={true}
    />

    <!-- WIP: CoBrain -->
    <div class="stagger-card flex items-start gap-4 p-5 md:p-6 rounded-2xl border border-dashed border-base-300">
      <div class="w-2 h-2 rounded-full bg-base-300 mt-2 flex-shrink-0"></div>
      <div>
        <div class="flex items-center gap-3 mb-1">
          <h3 class="text-base font-bold text-base-content/60">CoBrain</h3>
          <span class="text-[0.65rem] font-mono text-base-content/35 tracking-wide">WIP</span>
        </div>
        <p class="text-sm text-base-content/45 leading-relaxed">A shared, evidence-first brain for your lab. Upload PDFs, capture your group's definitions and standards, and ask questions to get cited, auditable answers — with built-in quality gates and refusal when evidence is thin.</p>
      </div>
    </div>
  </div>

  <AlsoBuilt />
</section>

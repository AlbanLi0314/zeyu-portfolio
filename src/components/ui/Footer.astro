	<aside>
		<p>
			Copyright © {new Date().getFullYear()} - All rights reserved by {fullName}
		</p>
		<p class="text-xs opacity-60 mt-1">
			This site collects server-side <a href="/_a/dashboard" class="underline hover:opacity-80">visit analytics</a>. No cookies are used.
		</p>
	</aside>
</footer>

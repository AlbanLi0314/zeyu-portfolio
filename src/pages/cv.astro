---
import Layout from '@/layouts/Layout.astro'
import { profile } from '@/settings'

const { fullName } = profile

const cvVersions = [
	{
		title: 'AI',
		description: 'Full-stack AI products, LLM integration & data pipelines',
		pdf: '/cv/Alban_Resume_AI.pdf',
		docx: '/cv/Alban_Resume_AI.docx',
		ats: '/cv/Alban_ATS_AI.docx',
		color: 'border-secondary',
		accent: 'bg-secondary',
	},
	{
		title: 'Materials',
		description: 'Polymers, hydrogels, functional surfaces & advanced characterization',
		pdf: '/cv/Alban_Resume_M.pdf',
		docx: '/cv/Alban_Resume_M.docx',
		ats: '/cv/Alban_ATS_M.docx',
		color: 'border-primary',
		accent: 'bg-primary',
	},
	{
		title: 'Biotech',
		description: 'Nucleic acid production, purification & biosensing',
		pdf: '/cv/Alban_Resume_B.pdf',
		docx: '/cv/Alban_Resume_B.docx',
		ats: '/cv/Alban_ATS_B.docx',
		color: 'border-accent',
		accent: 'bg-accent',
	},
]
---

<Layout title="Curriculum Vitae - Zeyu Li">
	<div class='max-w-5xl mx-auto'>
		<!-- Hero Section -->
		<div class='mb-10 md:mb-14'>
			<h1 class='text-3xl md:text-4xl font-bold mb-2 md:mb-4'>Curriculum Vitae</h1>
			<p class='text-base md:text-lg lg:text-xl text-base-content/70'>{fullName}</p>
			<div class="mt-4 inline-flex items-center px-3 py-1.5 rounded bg-primary text-white text-sm font-medium">
				Available for full-time roles starting May 2026.
			</div>
		</div>

		<!-- CV Cards -->
		<div class='grid md:grid-cols-3 gap-6'>
			{cvVersions.map((cv) => (
				<div class={`bg-base-100 border-2 border-base-300 rounded-lg overflow-hidden flex flex-col`}>
					<!-- Color top bar -->
					<div class={`${cv.accent} h-1.5`} />
					<div class='p-6 md:p-8 flex flex-col flex-1'>
						<h2 class='text-xl md:text-2xl font-bold text-base-content mb-2'>{cv.title}</h2>
						<p class='text-base text-base-content/60 mb-6 flex-1'>{cv.description}</p>
						<div class='flex flex-col gap-3'>
							<a href={cv.pdf} class='btn btn-primary btn-sm' download>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
								</svg>
								PDF
							</a>
							<a href={cv.docx} class='btn btn-outline btn-sm' download>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
								</svg>
								Word
							</a>
							<div class="tooltip tooltip-bottom w-full [--tooltip-color:theme(colors.base-200)] [--tooltip-text-color:theme(colors.base-content/0.6)]" data-tip="Formatted for applicant tracking systems">
								<a href={cv.ats} class='btn btn-outline btn-sm w-full' download>
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
									</svg>
									ATS Optimized
								</a>
							</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</Layout>
